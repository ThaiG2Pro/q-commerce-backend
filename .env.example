# Database cấu hình
DATABASE_URL=postgresql://neondb_owner:PASSWORD@HOST/neondb?sslmode=require
REDIS_URL=rediss://default:PASSWORD@HOST:6379

# CORS (Thêm http://localhost:3000 cho frontend của bạn)
STORE_CORS=http://localhost:8000,http://localhost:9000,http://localhost:3000
ADMIN_CORS=http://localhost:5173,http://localhost:9000,http://localhost:3000
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000,http://localhost:3000

# Secrets cho bảo mật (Vui lòng thay đổi khi deploy prod)
JWT_SECRET=change-me-in-production
COOKIE_SECRET=change-me-in-production

# Admin onboarding
MEDUSA_ADMIN_ONBOARDING_TYPE=nextjs
MEDUSA_ADMIN_ONBOARDING_NEXTJS_DIRECTORY=q-commerce-storefront
